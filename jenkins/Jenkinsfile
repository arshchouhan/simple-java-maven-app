pipeline {
    agent any

    environment {
        IMAGE_NAME = 'arshch246/simple-java-maven-app'
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    tools{
        maven "mymaven"
    }

    stages {

        stage('Clone') {
            steps {
                git url: 'https://github.com/arshchouhan/simple-java-maven-app.git',
                    branch: 'master',
                    credentialsId: 'myjenkins'
            }
        }

        stage('Maven Build') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
            }
        }

        stage('Push to Docker Hub') {
            steps {
                script {
                    withCredentials([string(credentialsId: 'dockerhub-pwd', variable: 'dockerhubpwd')]) {
                        sh "docker login -u arshch246 -p ${dockerhubpwd}"
                        sh "docker push ${IMAGE_NAME}:${IMAGE_TAG}"
                    }
                }
            }
        }

    }

    post {
        success {
            echo "Done! Image pushed: ${IMAGE_NAME}:${IMAGE_TAG}"
        }
        failure {
            echo "Pipeline failed."
        }
    }
}